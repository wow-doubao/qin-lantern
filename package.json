{
  "packageManager": "pnpm@11.3.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "ui:build": "pnpm --filter qin-lantern build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "utils:build": "pnpm --filter utils build",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3"
  }
}
