{
  "name": "qin-lantern",
  "version": "0.1.2",
  "author": "wzy",
  "keywords": [
    "element-plus",
    "component library",
    "ui",
    "vue"
  ],
  "description": "Component library encapsulating element-plus",
  "homepage": "https://wow-doubao.github.io/qin-lantern/",
  "repository": {
    "type": "github",
    "url": "https://github.com/wow-doubao/qin-lantern"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/qin-lantern.umd.cjs",
  "module": "./dist/qin-lantern.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/qin-lantern.js",
      "require": "./dist/qin-lantern.umd.cjs"
    },
    "./locale": {
      "types": "./dist/locale/index.d.ts",
      "import": "./dist/locale/index.js"
    },
    "./util": {
      "types": "./dist/util/index.d.ts",
      "import": "./dist/util/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "dev": "npm run docs:dev",
    "build": "vue-tsc && vite build && npm run build:locale && npm run build:util",
    "build:locale": "rollup -c ./utils/build-locale.js",
    "build:util": "rollup -c ./utils/build-util.js",
    "clean:lib": "rimraf yarn.lock && rimraf package-lock.json && rimraf node_modules && npm install",
    "plop": "plop --plopfile ./plop-templates/index.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/runtime-core": "^3.5.13",
    "@vueuse/core": "^13.0.0",
    "element-plus": "^2.9.7",
    "lodash-es": "^4.17.21",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.13",
    "@types/sortablejs": "^1.15.8",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.16.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "neostandard": "^0.12.1",
    "plop": "^4.0.1",
    "postcss": "^8.5.3",
    "rollup-plugin-typescript2": "^0.36.0",
    "sass": "^1.86.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "unocss": "^66.0.0",
    "unplugin-auto-import": "^19.1.1",
    "unplugin-element-plus": "^0.9.1",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.3",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-eslint": "^1.8.1",
    "vitepress": "^1.6.3",
    "vue-tsc": "^2.2.8"
  }
}
