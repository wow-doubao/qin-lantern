{
  "name": "qin-lantern",
  "type": "module",
  "version": "0.2.7",
  "description": "Component library encapsulating element-plus",
  "author": "wzy",
  "homepage": "https://wow-doubao.github.io/qin-lantern/",
  "repository": {
    "type": "github",
    "url": "https://github.com/wow-doubao/qin-lantern"
  },
  "keywords": [
    "element-plus",
    "component library",
    "ui",
    "vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/qin-lantern.js",
      "require": "./dist/qin-lantern.umd.cjs"
    },
    "./locale": {
      "types": "./dist/locale/index.d.ts",
      "import": "./dist/locale/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver/index.d.ts",
      "import": "./dist/resolver/index.js"
    },
    "./*": "./*"
  },
  "main": "./dist/qin-lantern.umd.cjs",
  "module": "./dist/qin-lantern.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "element-plus": "^2.11.8"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vue/runtime-core": "^3.5.34",
    "@vueuse/core": "^14.3.0",
    "element-plus": "^2.14.0",
    "lodash-unified": "^1.0.3",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "sass": "^1.100.0",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vue-tsc": "^3.3.1"
  }
}
