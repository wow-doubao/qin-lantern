{
  "compilerOptions": {
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "qin-lantern/*": [
        "./packages/*"
      ],
      "qin-lantern": [
        "./packages/index"
      ],
      "@/*": [
        "./docs/*"
      ]
    },
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    // "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "vite/client"
    ],
  },
  "include": [
    // ".vitepress/**/*",
    "typings/**/*",
    // "docs/**/*",
    "packages/**/*",
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}